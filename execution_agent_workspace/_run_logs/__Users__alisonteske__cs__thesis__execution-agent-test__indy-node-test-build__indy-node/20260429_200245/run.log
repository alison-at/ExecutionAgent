  "dockerfile_recommendation": "FROM ubuntu:20.04\n\nARG DEBIAN_FRONTEND=noninteractive\nENV TZ=Europe/Berlin\n\nRUN apt-get update && apt-get install -y git gnupg python3 python3-pip python3-dev g++ \\\n    wget apt-transport-https ca-certificates curl jq \\\n    libgflags-dev libsnappy-dev zlib1g-dev libbz2-dev liblz4-dev \\\n    zstd ruby ruby-dev rubygems gcc make \\\n    librocksdb-dev && rm -rf /var/lib/apt/lists/*\n\nRUN pip3 install -U setuptools==50.3.2 'pyzmq==22.3.0' Cython==0.29.36\n\nWORKDIR /app\n\nARG REPO_URL=https://github.com/hyperledger-indy/indy-node\nRUN git clone --depth 1 \"$REPO_URL\" indy_node\n\nWORKDIR /app/indy_node\n\nRUN pip --cache-dir /root/.cache/pip install .[tests]\n\nCMD [\"bash\"]",
  "dockerfile_used": "FROM ubuntu:20.04\n\nARG DEBIAN_FRONTEND=noninteractive\nENV TZ=Europe/Berlin\n\n# Install git and gnupg\nRUN apt-get update && apt-get install -y git gnupg\n\n# Adding repository signing keys\nRUN apt-key adv --keyserver keyserver.ubuntu.com --recv-keys 9692C00E657DDE61 && \\\n    apt-key adv --keyserver keyserver.ubuntu.com --recv-keys CE7709D068DB5E88\n\n# Adding apt sources for legacy packages\nRUN echo \"deb https://hyperledger.jfrog.io/artifactory/indy focal dev\" >> /etc/apt/sources.list\n\n# Update apt and install system dependencies, including g++ and RocksDB dev headers\nRUN apt-get update && apt-get install -y --no-install-recommends \\\n    wget apt-transport-https ca-certificates curl jq \\\n    python3 python3-pip python3-nacl python3-dev g++ \\\n    libgflags-dev libsnappy-dev zlib1g-dev libbz2-dev liblz4-dev \\\n    zstd ruby ruby-dev rubygems gcc make librocksdb-dev\n\n# Install Python build-time packages\nRUN pip3 install -U \\\n    setuptools==50.3.2 \\\n    'pyzmq==22.3.0' \\\n    Cython==0.29.36\n\n# Setup work directory\nWORKDIR /app\n\n# Clone the repository\nARG REPO_URL=https://github.com/hyperledger-indy/indy-node\nRUN git clone --depth 1 \"$REPO_URL\" indy_node\n\n# Change to the project directory\nWORKDIR /app/indy_node\n\n# Install the project and its test dependencies\nRUN pip --cache-dir /root/.cache/pip install .[tests]\n\n# Clean up apt cache\nRUN apt-get -y autoremove && rm -rf /var/lib/apt/lists/*\n\n# Command to run tests\nCMD [\"bash\"]"
}
