      "Dockerfile",
      "local",
      "/Users/alisonteske/cs/thesis/execution-agent-test/ExecutionAgent/execution_agent_workspace/execution_agent/iris/Dockerfile_path/Dockerfile",
      "FROM ubuntu:22.04\n\nARG DEBIAN_FRONTEND=noninteractive\nENV TZ=Europe/Berlin\n\n# Install git separately first\nRUN apt-get update && apt-get install -y git\n\n# Install other system dependencies\nRUN apt-get update && apt-get install -y --no-install-recommends \\\n    tzdata bash ca-certificates \\\n    curl sudo nano software-properties-common vim wget python3 python3-pip unzip tar apt-transport-https lsb-release \\\n    && ln -snf /usr/share/zoneinfo/$TZ /etc/localtime \\\n    && rm -rf /var/lib/apt/lists/*\n\nWORKDIR /app\n\n# Clone the repository\nRUN git clone https://github.com/iris-sast/iris.git\nWORKDIR /app/iris\n\n# Install Miniforge\nENV CONDA_DIR=/opt/conda\nENV PATH=$CONDA_DIR/bin:$PATH\n\nRUN wget --quiet https://github.com/conda-forge/miniforge/releases/download/4.10.3-10/Miniforge3-Linux-x86_64.sh -O /tmp/miniforge.sh && \\\n    chmod +x /tmp/miniforge.sh && \\\n    /tmp/miniforge.sh -b -p $CONDA_DIR && \\\n    rm /tmp/miniforge.sh && \\\n    conda clean -afy\n\n# Accept the conda terms of service\nRUN conda tos accept\n\n# Create and activate the conda environment using environment.yml\nRUN conda env create -f environment.yml\n\n# Set up conda environment activation\nSHELL [\"/bin/bash\", \"-c\"]\nRUN echo \"conda activate iris\" >> ~/.bashrc\n\nCMD [\"/bin/bash\"]"
